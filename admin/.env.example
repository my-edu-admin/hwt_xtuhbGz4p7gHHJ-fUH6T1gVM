ADMIN_HOST=0.0.0.0
ADMIN_PORT=3000
ADMIN_SERVE_USER_BUILD=true
ADMIN_USER_ROUTE=/user
ADMIN_ALLOW_REMOTE_ACCESS=false

# Full source repository used by the Source App.
ADMIN_GIT_REPO_PATH=.
ADMIN_GIT_REMOTE=origin
ADMIN_GIT_DEFAULT_BRANCH=

# Separate public-data repository used by the DB Manager.
# This can be a local clone path or a GitHub repository URL.
# If you use a URL, the admin server clones it into admin/db-mirror-repo.
ADMIN_DB_REPO_PATH=
ADMIN_DB_REMOTE=origin
ADMIN_DB_DEFAULT_BRANCH=

# Folder names inside the public-data repository.
ADMIN_DB_BASIC_TARGET=basic
ADMIN_DB_DETAILED_TARGET=detailed

# Optional SMTP setup for Mail Center.
ADMIN_SMTP_HOST=
ADMIN_SMTP_PORT=587
ADMIN_SMTP_SECURE=false
ADMIN_SMTP_USER=
ADMIN_SMTP_PASS=
ADMIN_EMAIL_FROM_NAME=EduData Nepal
ADMIN_EMAIL_FROM_ADDRESS=
ADMIN_EMAIL_REPLY_TO=
